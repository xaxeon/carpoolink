{
  "name": "carpoolink",
  "version": "1.0.0",
  "description": "Carpoolink modular mentoring platform workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "prisma": {
    "seed": "node packages/database/prisma/seed.js"
  },
  "scripts": {
    "start": "npm run start -w services/core-api",
    "db:setup": "npm install && npx prisma generate --schema=./packages/database/prisma/schema.prisma && npx prisma db push --schema=./packages/database/prisma/schema.prisma && npx prisma db seed --schema=./packages/database/prisma/schema.prisma",
    "dev": "npm run dev:core",
    "dev:core": "npm run dev -w services/core-api",
    "dev:media": "npm run dev -w services/media-server",
    "dev:chat": "npm run dev -w services/chat-service",
    "dev:question": "npm run dev -w services/question-service",
    "dev:stt": "npm run dev -w services/stt-service",
    "test": "npm run test -ws --if-present"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.1",
    "form-data": "^4.0.5",
    "fs": "^0.0.1-security",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "nodejs-whisper": "^0.2.9",
    "openai": "^6.34.0"
  }
}
