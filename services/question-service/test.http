### Health check
GET http://localhost:4003/health

### Question detection
POST http://localhost:4003/api/question-detection/predict
Content-Type: application/json

{
  "text": "이 부분 다시 설명해주실 수 있나요?"
}

### Question clustering
POST http://localhost:4003/api/question-clustering/cluster
Content-Type: application/json

{
  "questions": [
    {
      "id": "q1",
      "text": "useState 값이 바로 안 바뀌는 이유가 뭔가요?"
    },
    {
      "id": "q2",
      "text": "useEffect는 언제 실행되나요?"
    }
  ],
  "similarityMode": "rule",
  "threshold": 0.5
}

### Rank one question
POST http://localhost:4003/api/questions/rank
Content-Type: application/json

{
  "question": "useState 값이 바로 안 바뀌는 이유가 뭔가요?",
  "isPaid": true,
  "sessionTopic": "React state management",
  "currentScriptSection": "useState updates are reflected on the next render.",
  "mentorProfile": "React frontend mentor",
  "menteeProfile": "Beginner React learner"
}

### Rank an existing clustering result
POST http://localhost:4003/api/questions/rank
Content-Type: application/json

{
  "sessionTopic": "React state management",
  "currentScriptSection": "useState updates are reflected on the next render.",
  "mentorProfile": "React frontend mentor",
  "menteeProfile": "Beginner React learner",
  "questions": [
    {
      "id": "q1",
      "text": "useState 값이 바로 안 바뀌는 이유가 뭔가요?",
      "isPaid": true
    },
    {
      "id": "q2",
      "text": "useEffect는 언제 실행되나요?",
      "isPaid": false
    }
  ],
  "clustering": {
    "question_count": 2,
    "cluster_count": 1,
    "threshold": 0.5,
    "similarity_mode": "rule",
    "embedding_model": null,
    "clusters": [
      {
        "cluster_id": "cluster_1",
        "representative_question_id": "q1",
        "representative_question": "useState 값이 바로 안 바뀌는 이유가 뭔가요?",
        "best_match_score": 0.71,
        "member_questions": [
          {
            "question_id": "q1",
            "text": "useState 값이 바로 안 바뀌는 이유가 뭔가요?"
          },
          {
            "question_id": "q2",
            "text": "useEffect는 언제 실행되나요?"
          }
        ]
      }
    ]
  }
}

### Question recommendations
POST http://localhost:4003/api/questions/recommendations
Content-Type: application/json

{
  "context": "React useState and useEffect live mentoring session.",
  "count": 3,
  "mentee": {
    "id": "mentee-1",
    "level": "beginner",
    "interests": ["React"]
  },
  "mentor": {
    "id": "mentor-1",
    "role": "frontend mentor",
    "expertise": ["React", "state management"]
  }
}
